# 童梦AI 自动部署配置（复制为 deploy.config.env 并填写）
# cp deploy.config.example.env deploy.config.env

# 远程服务器
DEPLOY_HOST=your-server.com
DEPLOY_USER=ubuntu
DEPLOY_PORT=22
DEPLOY_PATH=/opt/tongmeng-ai

# SSH 私钥路径（可选，默认使用 ~/.ssh/id_rsa）
# DEPLOY_SSH_KEY=/home/user/.ssh/deploy_key

# 服务端端口
SERVER_PORT=9050

# 部署 webhook 密钥（与服务器环境变量 DEPLOY_WEBHOOK_SECRET 一致）
DEPLOY_WEBHOOK_SECRET=your-random-secret-here

# 跳过 APK 构建（仅部署 Web+服务端）
# SKIP_APK=1

# GitHub 自动推送（可选，用于 setup-github-ssh.sh 自动添加 SSH Key）
# 在 GitHub → Settings → Developer settings → Personal access tokens 创建
# 权限: admin:public_key, repo
# GITHUB_TOKEN=ghp_xxxxxxxx

# GitHub 仓库（SSH）
# GIT_REMOTE=origin
# GIT_BRANCH=main
#   DEPLOY_HOST          - 服务器 IP/域名
#   DEPLOY_USER          - SSH 用户名
#   DEPLOY_SSH_KEY       - SSH 私钥全文
#   DEPLOY_PATH          - 部署目录
#   DEPLOY_WEBHOOK_SECRET - 部署密钥
#   SERVER_PORT          - 9050（可选）
